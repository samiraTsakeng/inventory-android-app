<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="wise_view_inventory_form" model="ir.ui.view">
        <field name="name">wise_view_inventory.form</field>
        <field name="model">stock.inventory</field>
        <field name="inherit_id" ref="stock.view_inventory_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button class="oe_stat_button" attrs="{'invisible': [('is_general', '=', False)]}" name="counting_sheet" string="Feuilles de Comptage" type="object" icon="fa-list" />
                <button class="oe_stat_button" attrs="{'invisible': [('is_general', '=', False)]}" name="consolidation_sheet" string="Feuilles de Consolidation" type="object" icon="fa-list" />
                
            </div>
            <xpath expr="//field[@name='filter']" position="after">
                <field name="is_general" invisible="1"/>
                <field name="manager_id" attrs="{'invisible': [('is_general', '=', False)]}"/>
                <field name="consolidated_sheet_ids" widget="many2many_tags" readonly="1" attrs="{'invisible': [('is_general', '=', False)]}"/>
            </xpath> 
            
            <xpath expr="//button[@name='action_cancel_draft']" position="after">
                <field name="display_consolid" invisible="1"/>
                <button string="Intégrer les consolidations" name="update_adjustement" attrs="{'invisible': ['|', ('display_consolid', '=', False), ('state', '!=', 'confirm')]}" type="object" class="oe_highlight"/>
                <button string="Rapport Excel" name="generate_excel_report" attrs="{'invisible': ['|', ('is_general', '=', False), ('state', '!=', 'done')]}" type="object" class="oe_highlight"/>
            </xpath>
            <xpath expr="//button[@name='action_reset_product_qty']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_check_serial']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']" position="attributes">
                <attribute name="attrs">{'readonly': ['|', ('is_general', '=', True), ('state', '=', 'done')]}</attribute>
            </xpath>
            <xpath expr="//field[@name='location_id']" position="attributes">
                <attribute name="domain">[('usage', '=', 'internal')]</attribute>
            </xpath>
            <xpath expr="//field[@name='line_ids']/tree" position="replace">
                <tree editable="bottom" decoration-info="product_qty != theoretical_qty" decoration-danger="theoretical_qty &lt; 0">
                    <field name="number" required="1"/>
                    <field name="prod_lot_id" invisible="1" />
                    <field name="product_id" readonly="1" />
                    <field name="product_uom_id" groups="product.group_uom" string="UoM"/>
                    <field name="location_id" domain="[('id', 'child_of', parent.location_id)]" invisible="1"/>
                    <field name="package_id" domain="['|', ('location_id','=', False), ('location_id', '=', location_id)]" groups="stock.group_tracking_lot"/>
                    <field name="partner_id" groups="stock.group_tracking_owner"/>
                    <field name="theoretical_qty" readonly="1"/>
                    <field name="product_qty" />
                    <field name="state" invisible="True"/>
                </tree>
            </xpath>
        </field>
    </record>


</odoo>
