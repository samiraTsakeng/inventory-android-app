<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_inventory" model="ir.module.category">
        <field name="name">Ajustement Général</field>
    </record>

    <record id="resp_inventory" model="res.groups">
        <field name="name">Resp. Ajustement</field>
        <field name="category_id" ref="wise_inventory.module_category_inventory" />
        <field name="users" eval="[(4, ref('base.user_root'))]"/>
    </record>

    <record id="counting_group" model="res.groups">
        <field name="name">Resp. Comptage</field>
        <field name="category_id" ref="wise_inventory.module_category_inventory" />
        <field name="users" eval="[(4, ref('base.user_root'))]"/>
    </record>

    <record id="counting_sheet_rule" model="ir.rule">
        <field name="name">Mes Feuilles de Comptage</field>
        <field name="model_id" ref="model_counting_sheet" />
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('wise_inventory.counting_group'))]" />
    </record>
    
    <record id="resp_ajustment_rule" model="ir.rule">
        <field name="name">Mes Ajustements</field>
        <field name="model_id" ref="model_counting_sheet" />
        <field name="domain_force">[('stock_inventory_id.manager_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('wise_inventory.resp_inventory'))]" />
    </record>

    <record id="access_stock_inventory" model="ir.model.access">
        <field name="name">Accès sur Ajustement</field>
        <field name="model_id" ref="model_stock_inventory"/>
        <field name="group_id" ref="wise_inventory.counting_group"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>
    
    <record id="access_counting_sheet_user" model="ir.model.access">
        <field name="name">Accès aux Feuilles</field>
        <field name="model_id" ref="model_counting_sheet"/>
        <field name="group_id" ref="wise_inventory.counting_group"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>
    
    <record id="access_counting_sheet_resp" model="ir.model.access">
        <field name="name">Accès aux Feuilles</field>
        <field name="model_id" ref="model_counting_sheet"/>
        <field name="group_id" ref="wise_inventory.resp_inventory"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
    
    <record id="access_zone_resp" model="ir.model.access">
        <field name="name">Accès aux Zones</field>
        <field name="model_id" ref="model_zone_rangement"/>
        <field name="group_id" ref="wise_inventory.resp_inventory"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

</odoo>